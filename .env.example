# ============================================================================
# Bloomkite environment variables
# ----------------------------------------------------------------------------
# Copy this file to one of:
#   .env.local  - local development        (npm run dev, npm run db:migrate)
#   .env.test   - test database            (npm run db:test:migrate)
#   .env.prod   - PRODUCTION database      (npm run db:prod:migrate)
#
# .env.local, .env.test, .env.prod must all be listed in .gitignore.
# NEVER commit .env.prod — it points at the live Supabase project.
# ============================================================================

# Node runtime.
NODE_ENV=development

# ----------------------------------------------------------------------------
# Postgres database (Supabase Postgres — auth is handled by Auth.js, not Supabase)
# ----------------------------------------------------------------------------
# Direct connection used by scripts/migrate.ts and Prisma migrations.
SUPABASE_DB_HOST=your_db_host
SUPABASE_DB_PORT=5432
SUPABASE_DB_PASSWORD=your_database_password
SUPABASE_DB_SSL=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres

# Prisma URLs. DATABASE_URL is the runtime connection (pooled in prod);
# DIRECT_URL is the unpooled connection used by `prisma migrate`.
# Local dev: both point at port 54322 (Supabase CLI stack, no pooler).
# Prod: DATABASE_URL uses pgbouncer (port 6543), DIRECT_URL uses port 5432.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public

# ----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ----------------------------------------------------------------------------
# Random 32+ byte secret. Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret

# ----------------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------------
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ----------------------------------------------------------------------------
# Resend (transactional email — verification + password reset)
# ----------------------------------------------------------------------------
# Get key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
# Until a domain is verified in Resend, use onboarding@resend.dev.
EMAIL_FROM=onboarding@resend.dev

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
