# ============================================================================
# Bloomkite environment variables
# ----------------------------------------------------------------------------
# Copy this file to one of:
#   .env.local  - local development        (npm run db:migrate)
#   .env.test   - test database            (npm run db:test:migrate)
#   .env.prod   - PRODUCTION database      (npm run db:prod:migrate)
#
# .env.local, .env.test, .env.prod must all be listed in .gitignore.
# NEVER commit .env.prod — it points at the live Supabase project.
# ============================================================================

# Node runtime. The test-login API route is disabled when this is "production".
NODE_ENV=development

# ----------------------------------------------------------------------------
# Supabase (REQUIRED for all environments)
# ----------------------------------------------------------------------------
# Public URL + anon key are exposed to the browser; safe to ship in client bundles.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — server-side only. Bypasses RLS. Use only for admin work.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# DB password — only needed by the migration runner (scripts/migrate.ts).
# Not required at app runtime.
SUPABASE_DB_PASSWORD=your_database_password

# ----------------------------------------------------------------------------
# Google OAuth (REQUIRED for local + prod; optional for test)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
