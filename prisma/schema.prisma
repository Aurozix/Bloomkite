  pdfUrl            String?   @map("pdf_url")
  issuedAt          DateTime? @default(now()) @map("issued_at") @db.Timestamp(6)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subscriptionId], map: "idx_invoices_subscription_id")
  @@index([userId], map: "idx_invoices_user_id")
  @@map("invoices")
}

// ============================================================================
// AI feature flags
// ============================================================================

/// One row per AI-shaped feature in the product. Toggled from /admin/ai-features
/// by users with the `manage_ai_features` permission. Default `isEnabled =
/// false` on every insert — AI features are opt-in, never opt-out. Brand voice
/// and SEBI compliance both demand that.
///
/// `slug` is the primary key and the runtime lookup key. Pick stable values
/// (`nri-tax-explainer`, `calc-narration`, `forum-pre-moderation`). Don't rename
/// once shipped; the runtime `isAIFeatureEnabled('...')` calls would silently
/// return false.
///
/// `category` groups features in the admin UI: 'investor-support',
/// 'content-moderation', 'advisor-tools'. Free-form on insert; UI groups
/// by exact string match.
///
/// `updatedBy` references the admin who last toggled the flag. Each toggle
/// also writes a row to admin_audit with action='ai_feature.toggle'.
model AIFeature {
  slug        String   @id @db.VarChar(100)
  category    String   @db.VarChar(50)
  name        String   @db.VarChar(150)
  description String
  isEnabled   Boolean  @default(false) @map("is_enabled")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([category], map: "idx_ai_features_category")
  @@map("ai_features")
}

// ============================================================================
// Admin audit log
// ============================================================================

/// Append-only audit trail for admin actions. Required by BRD §8.3 / §13.2
/// (audit trail) and SEBI compliance. Never delete rows; never UPDATE except
/// in extraordinary cases. Actor FK uses NoAction so deleting a former admin
/// preserves the trail.
///
/// `action` is a dot-separated verb: `user.disable`, `user.enable`,
/// `user.role.add`, `user.role.remove`, `ai_feature.toggle`. Keep them
/// stable — the admin UI groups + filters by these strings.
///
/// `targetType` + `targetId` identify the affected entity. `targetId` is a
/// string (not a UUID FK) so it can hold either a user UUID or a slug like
/// "nri-tax-explainer" for AI features. Index covers (targetType, targetId).
///
/// `metadata` is free-form JSON; convention is `{ before, after }` for state
/// transitions. Don't read it from app code; it's for human auditors.
model AdminAudit {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(100)
  targetType  String?  @map("target_type") @db.VarChar(50)
  targetId    String?  @map("target_id") @db.VarChar(200)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  actor User @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: NoAction)

  @@index([actorUserId], map: "idx_admin_audit_actor")
  @@index([targetType, targetId], map: "idx_admin_audit_target")
  @@index([createdAt(sort: Desc)], map: "idx_admin_audit_created")
  @@map("admin_audit")
}

// ============================================================================
// Internal — owned by the custom migration runner (scripts/migrate.ts).
// Prisma is aware of it so migrations don't try to drop it.
// ============================================================================

/// Tracking table for the raw-SQL migration runner. Not used by app code.
model MigrationRecord {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(255)
  executedAt DateTime? @default(now()) @map("executed_at") @db.Timestamp(6)

  @@map("migrations")
}
