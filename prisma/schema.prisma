// Bloomkite Prisma schema
// Source of truth for all DB schema changes going forward.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Auth.js (NextAuth v5) models
// ============================================================================

/// Canonical user table. Owned by Auth.js after the Supabase Auth migration.
/// passwordHash is null for OAuth-only users. emailVerified is null until the
/// user clicks the verification link (Google sign-ins are auto-verified by the
/// signIn callback).
/// disabledAt is set when an admin soft-disables the account; the signIn
/// callback in auth.ts blocks any sign-in attempt while it's non-null.
model User {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  name            String?   @map("full_name") @db.VarChar(255)
  image           String?   @map("avatar_url")
  emailVerified   DateTime? @map("email_verified") @db.Timestamp(6)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  // BRD §8.1: Adults Only — platform requires 18+. Nullable so existing rows
  // (pre-DOB-rollout) keep working; activation paths require it before
  // creating a profile. InvestorProfile/AdvisorProfile still carry their own
  // dateOfBirth columns as denormalised copies for historical reasons.
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  // BRD §8.1: Email + Phone OTP. Profile activation refuses to proceed
  // without a verified phone. `phoneNumber` is the E.164 string captured
  // during the OTP send (mirrored to the role's profile on success).
  phoneNumber     String?   @map("phone_number") @db.VarChar(20)
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamp(6)
  disabledAt      DateTime? @map("disabled_at") @db.Timestamp(6)
  disabledBy      String?   @map("disabled_by") @db.Uuid
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  accounts            Account[]
  passwordResetTokens PasswordResetToken[]
  userRoles           UserRole[]
  investorProfile     InvestorProfile?
  advisorProfile      AdvisorProfile?      @relation("AdvisorProfileUser")
  approvedAdvisors    AdvisorProfile[]     @relation("AdvisorProfileApprover")
  advisorCredentials  AdvisorCredential[]
  advisorExpertise    AdvisorExpertise[]
  followingAdvisors   AdvisorFollower[]    @relation("FollowingAdvisors")
  followers           AdvisorFollower[]    @relation("AdvisorFollowers")
  articles            Article[]
  financialPlans      FinancialPlan[]
  forumQuestions      ForumQuestion[]
  forumAnswers        ForumAnswer[]
  forumAnswerVotes    ForumAnswerVote[]
  invoices            Invoice[]
  subscriptions       Subscription[]
  advisorProducts     AdvisorProduct[]     @relation("AdvisorProductsForUser")
  advisorServices     AdvisorService[]     @relation("AdvisorServicesForUser")
  advisorBrands       AdvisorBrand[]       @relation("AdvisorBrandsForUser")
  ratingsReceived     AdvisorRating[]      @relation("AdvisorRated")
  ratingsGiven        AdvisorRating[]      @relation("InvestorRated")
  forumTagsReceived   ForumQuestionAdvisorTag[] @relation("ForumTaggedAdvisor")
  planSharesReceived  PlanShare[]          @relation("PlanSharesReceived")
  planCommentsAuthored PlanComment[]       @relation("PlanCommentsAuthored")
  adminAuditActions   AdminAudit[]         @relation("AdminAuditActor")
  disabler            User?                @relation("UserDisabler", fields: [disabledBy], references: [id], onDelete: NoAction)
  disabledUsers       User[]               @relation("UserDisabler")

  @@index([email], map: "idx_users_email")
  @@index([disabledAt], map: "idx_users_disabled_at")
  @@map("users")
}

/// OAuth provider account linkage (NextAuth standard).
/// Field names refresh_token, access_token, expires_at, token_type, id_token,
/// session_state MUST be snake_case — Auth.js Prisma adapter queries them by
/// these exact names per the OAuth 2.0 spec.
model Account {
  id                String  @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

/// Email verification tokens (NextAuth standard shape).
/// Used to verify email addresses on sign-up via Resend.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// 6-digit OTP codes for email verification at signup.
///
/// Separate from VerificationToken (which Auth.js owns and constrains
/// token-uniqueness on, an awkward fit for a 6-digit value with only a
/// million possibilities). codeHash stores SHA-256 of the raw code so DB
/// compromise doesn't leak in-flight OTPs. `attempts` rate-limits brute
/// force; the route invalidates the row after 5 wrong tries.
///
/// Each new send for a given email deletes prior rows for that email — we
/// never want two valid codes outstanding at the same time.
model EmailVerificationOtp {
  id        String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  email     String   @db.VarChar(255)
  codeHash  String   @map("code_hash") @db.VarChar(64)
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([email], map: "idx_email_otp_email")
  @@index([expiresAt], map: "idx_email_otp_expires")
  @@map("email_verification_otps")
}

// ============================================================================
// Master data
// ============================================================================
//
// One table per domain (per design decision 2026-05-13 — see Gap_Analysis §9).
// Each row is a globally-stable concept that profile pages, calculators, and
// admin search filters reference by id. `slug` is the human-stable handle
// that code can hard-code; `name` is the display label that admins edit.
//
// `isActive` lets admins retire a row without breaking historical references
// (advisor still has it on their profile, but new advisors can't pick it).

/// Investment categories for investor profile interest declaration
/// (BRD §3.1 step 4). Equity, MF, Insurance, Fixed Income, etc.
model MasterDataInvestmentCategory {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(150)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  investorInterests InvestorInvestmentInterest[]

  @@index([sortOrder, name], map: "idx_md_inv_cat_order")
  @@map("master_data_investment_categories")
}

/// Investor ↔ investment categories M:N. BRD §3.1 step 4. No priority — every
/// declared category is "interested in" with equal weight.
model InvestorInvestmentInterest {
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  category MasterDataInvestmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([userId], map: "idx_investor_interest_user")
  @@map("investor_investment_interests")
}

/// Products an advisor can offer (BRD §3.2 step 5). Mutual Funds, Insurance,
/// Fixed Deposits, PMS, AIF, Bonds, ULIPs.
model MasterDataProduct {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(150)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  advisorProducts AdvisorProduct[]

  @@index([sortOrder, name], map: "idx_md_product_order")
  @@map("master_data_products")
}

/// Services an advisor offers (BRD §3.2 step 5). Wealth Management,
/// Retirement Planning, Tax Planning, Estate Planning, etc.
model MasterDataService {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(150)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  advisorServices AdvisorService[]

  @@index([sortOrder, name], map: "idx_md_service_order")
  @@map("master_data_services")
}

/// Brands / financial institutions an advisor works with (BRD §3.2 step 5).
/// HDFC, ICICI, SBI, Kotak, etc.
model MasterDataBrand {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(150)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  advisorBrands AdvisorBrand[]

  @@index([sortOrder, name], map: "idx_md_brand_order")
  @@map("master_data_brands")
}

// ============================================================================
// Advisor declarations (BRD §3.2 step 5-6)
// ============================================================================
//
// Three join tables connect an advisor's userId to the master_data they've
// declared. Products + Services carry a `priority` column for advisor ranking
// (BRD §3.2 step 6 — "assign priority/preference to products/services");
// Brands do not — the BRD doesn't ask for brand ranking. Priorities are
// 1-based ints, 1 = highest preference; gaps are tolerated (we don't
// renumber on delete) so reorders are cheap.

/// Advisor ↔ products M:N with priority ranking.
model AdvisorProduct {
  userId     String   @map("user_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  priority   Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user    User              @relation("AdvisorProductsForUser", fields: [userId], references: [id], onDelete: Cascade)
  product MasterDataProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([userId, priority], map: "idx_advisor_product_priority")
  @@index([productId], map: "idx_advisor_product_product")
  @@map("advisor_products")
}

/// Advisor ↔ services M:N with priority ranking.
model AdvisorService {
  userId     String   @map("user_id") @db.Uuid
  serviceId  String   @map("service_id") @db.Uuid
  priority   Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user    User              @relation("AdvisorServicesForUser", fields: [userId], references: [id], onDelete: Cascade)
  service MasterDataService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
  @@index([userId, priority], map: "idx_advisor_service_priority")
  @@index([serviceId], map: "idx_advisor_service_service")
  @@map("advisor_services")
}

/// Advisor ↔ brands M:N. No priority — BRD §3.2 step 6 ranks products and
/// services only.
model AdvisorBrand {
  userId    String   @map("user_id") @db.Uuid
  brandId   String   @map("brand_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user  User            @relation("AdvisorBrandsForUser", fields: [userId], references: [id], onDelete: Cascade)
  brand MasterDataBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([userId, brandId])
  @@index([userId], map: "idx_advisor_brand_user")
  @@index([brandId], map: "idx_advisor_brand_brand")
  @@map("advisor_brands")
}

/// Account types an investor can declare in onboarding (BRD §3.1 step 5).
/// Bank Savings, Brokerage, Mutual Funds, PPF, EPF, NPS, Insurance.
/// We deliberately capture only WHICH types the investor holds, not balances
/// or amounts — BRD §8.5 data minimisation.
model MasterDataAccountType {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(150)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  investorFinancialAccounts InvestorFinancialAccount[]

  @@index([sortOrder, name], map: "idx_md_account_type_order")
  @@map("master_data_account_types")
}

/// Investor financial accounts (BRD §3.1 step 5).
///
/// One row per account-type-and-optional-institution. Deliberately NO
/// balance/amount fields — BRD §8.5 data minimisation, and Bloomkite is an
/// advisor-discovery platform not a portfolio tracker. Multiple rows allowed
/// for the same accountType (e.g. two different banks).
model InvestorFinancialAccount {
  id              String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  accountTypeId   String   @map("account_type_id") @db.Uuid
  institutionName String?  @map("institution_name") @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  accountType MasterDataAccountType @relation(fields: [accountTypeId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_inv_fin_acct_user")
  @@map("investor_financial_accounts")
}

/// 6-digit OTP codes for phone verification. Same hash + attempts pattern as
/// EmailVerificationOtp; keyed by userId since phone numbers can change
/// during onboarding (user enters wrong number → retry with a new one
/// invalidates the prior code). The `phoneNumber` column captures which
/// number this code was sent to, so a successful verify can write back to
/// User.phoneNumber knowing the user typed the right number on this attempt.
model PhoneVerificationOtp {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  phoneNumber String   @map("phone_number") @db.VarChar(20)
  codeHash    String   @map("code_hash") @db.VarChar(64)
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([userId], map: "idx_phone_otp_user")
  @@index([expiresAt], map: "idx_phone_otp_expires")
  @@map("phone_verification_otps")
}

/// Password reset tokens. Stored as a SHA-256 hash; the raw token is sent
/// in the reset link and never persisted. expiresAt is 1h from creation.
/// usedAt is set on first use to prevent token replay.
model PasswordResetToken {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamp(6)
  usedAt    DateTime? @map("used_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_reset_tokens_user_id")
  @@index([expiresAt], map: "idx_password_reset_tokens_expires_at")
  @@map("password_reset_tokens")
}

// ============================================================================
// RBAC
// ============================================================================

model Role {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(50)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId], map: "idx_role_permissions_role_id")
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([userId], map: "idx_user_roles_user_id")
  @@map("user_roles")
}

// ============================================================================
// Profiles
// ============================================================================

model InvestorProfile {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  displayName String?   @map("display_name") @db.VarChar(255)
  phoneNumber String?   @map("phone_number") @db.VarChar(20)
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      String?   @db.VarChar(20)
  city        String?   @db.VarChar(100)
  state       String?   @db.VarChar(100)
  pincode     String?   @db.VarChar(10)
  riskProfile String?   @map("risk_profile") @db.VarChar(50)
  bio         String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_investor_profiles_user_id")
  @@map("investor_profiles")
}

model AdvisorProfile {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  displayName     String?   @map("display_name") @db.VarChar(255)
  phoneNumber     String?   @map("phone_number") @db.VarChar(20)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?   @db.VarChar(20)
  companyName     String?   @map("company_name") @db.VarChar(255)
  designation     String?   @db.VarChar(100)
  panNumber       String?   @map("pan_number") @db.VarChar(20)
  gstNumber       String?   @map("gst_number") @db.VarChar(20)
  // BRD §3.2 step 3: Professional Information — years of experience and the
  // advisor's SEBI/IRDA/etc. registration number. Optional during onboarding
  // so the profile shell can exist; required before workflowStatus moves to
  // "approved" (admin gate enforces).
  yearsOfExperience      Int?     @map("years_of_experience")
  licenseRegistrationNumber String? @map("license_registration_number") @db.VarChar(100)
  licenseRegistrationBody   String? @map("license_registration_body") @db.VarChar(100)
  addressLine1    String?   @map("address_line1") @db.VarChar(255)
  addressLine2    String?   @map("address_line2") @db.VarChar(255)
  city            String?   @db.VarChar(100)
  state           String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  websiteUrl      String?   @map("website_url")
  bio             String?
  profileImageUrl String?   @map("profile_image_url")
  workflowStatus  String?   @default("pending") @map("workflow_status") @db.VarChar(50)
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamp(6)
  isVerified      Boolean?  @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamp(6)
  followerCount   Int       @default(0) @map("follower_count")
  /// Denormalised aggregates for the public profile rating card. Kept in sync
  /// by the rating routes (recompute inside the same transaction as
  /// create/update/delete). BRD §7.1 high-priority — average is shown
  /// prominently; ratingCount qualifies the average ("4.6 from 23 reviews").
  /// ratingAverage stored as Decimal(3,2) so 4.67 is exact, no float drift.
  ratingCount     Int       @default(0) @map("rating_count")
  ratingAverage   Decimal?  @map("rating_average") @db.Decimal(3, 2)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user     User  @relation("AdvisorProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("AdvisorProfileApprover", fields: [approvedBy], references: [id], onDelete: NoAction)

  @@index([followerCount(sort: Desc)], map: "idx_advisor_profiles_follower_count")
  @@index([ratingAverage(sort: Desc)], map: "idx_advisor_profiles_rating_average")
  @@index([userId], map: "idx_advisor_profiles_user_id")
  @@index([workflowStatus], map: "idx_advisor_profiles_workflow_status")
  @@map("advisor_profiles")
}

/// Advisor credentials. BRD §3.2 step 4 distinguishes four classes —
/// Certifications, Awards, Education, Experience. We use one table with a
/// `credentialClass` discriminator + class-specific nullable fields, not four
/// separate tables (per 2026-05-13 design call). All existing pre-rollout
/// rows were certifications; the migration backfills credentialClass to
/// 'CERTIFICATION' on every existing row.
///
/// Field semantics by class:
///   CERTIFICATION : credentialType=title, issuer, licenseNumber, expiryDate
///   AWARD         : credentialType=title, issuer=awarding body, awardYear
///   EDUCATION     : credentialType=degree, issuer=institution, awardYear=grad year
///   EXPERIENCE    : credentialType=role, issuer=company, startDate, endDate (null = current)
model AdvisorCredential {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  credentialClass String    @default("CERTIFICATION") @map("credential_class") @db.VarChar(50)
  credentialType  String    @map("credential_type") @db.VarChar(100)
  issuer          String?   @db.VarChar(255)
  licenseNumber   String?   @map("license_number") @db.VarChar(100)
  expiryDate      DateTime? @map("expiry_date") @db.Date
  // For AWARD (year of award) and EDUCATION (year of graduation).
  awardYear       Int?      @map("award_year")
  // For EXPERIENCE only. endDate is null while the role is current.
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  fileUrl         String?   @map("file_url")
  status          String?   @default("pending") @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_advisor_credentials_status")
  @@index([userId], map: "idx_advisor_credentials_user_id")
