// Bloomkite Prisma schema
// Source of truth for all DB schema changes going forward.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Auth.js (NextAuth v5) models
// ============================================================================

/// Canonical user table. Owned by Auth.js after the Supabase Auth migration.
/// passwordHash is null for OAuth-only users. emailVerified is null until the
/// user clicks the verification link (Google sign-ins are auto-verified by the
/// signIn callback).
model User {
  id            String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  name          String?   @map("full_name") @db.VarChar(255)
  image         String?   @map("avatar_url")
  emailVerified DateTime? @map("email_verified") @db.Timestamp(6)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  accounts            Account[]
  passwordResetTokens PasswordResetToken[]
  userRoles           UserRole[]
  investorProfile     InvestorProfile?
  advisorProfile      AdvisorProfile?      @relation("AdvisorProfileUser")
  approvedAdvisors    AdvisorProfile[]     @relation("AdvisorProfileApprover")
  advisorCredentials  AdvisorCredential[]
  advisorExpertise    AdvisorExpertise[]
  followingAdvisors   AdvisorFollower[]    @relation("FollowingAdvisors")
  followers           AdvisorFollower[]    @relation("AdvisorFollowers")
  articles            Article[]
  financialPlans      FinancialPlan[]
  forumQuestions      ForumQuestion[]
  forumAnswers        ForumAnswer[]
  forumAnswerVotes    ForumAnswerVote[]
  invoices            Invoice[]
  subscriptions       Subscription[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

/// OAuth provider account linkage (NextAuth standard).
/// Field names refresh_token, access_token, expires_at, token_type, id_token,
/// session_state MUST be snake_case — Auth.js Prisma adapter queries them by
/// these exact names per the OAuth 2.0 spec.
model Account {
  id                String  @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

/// Email verification tokens (NextAuth standard shape).
/// Used to verify email addresses on sign-up via Resend.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Password reset tokens. Stored as a SHA-256 hash; the raw token is sent
/// in the reset link and never persisted. expiresAt is 1h from creation.
/// usedAt is set on first use to prevent token replay.
model PasswordResetToken {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamp(6)
  usedAt    DateTime? @map("used_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_reset_tokens_user_id")
  @@index([expiresAt], map: "idx_password_reset_tokens_expires_at")
  @@map("password_reset_tokens")
}

// ============================================================================
// RBAC
// ============================================================================

model Role {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(50)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId], map: "idx_role_permissions_role_id")
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([userId], map: "idx_user_roles_user_id")
  @@map("user_roles")
}

// ============================================================================
// Profiles
// ============================================================================

model InvestorProfile {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  displayName String?   @map("display_name") @db.VarChar(255)
  phoneNumber String?   @map("phone_number") @db.VarChar(20)
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      String?   @db.VarChar(20)
  city        String?   @db.VarChar(100)
  state       String?   @db.VarChar(100)
  pincode     String?   @db.VarChar(10)
  riskProfile String?   @map("risk_profile") @db.VarChar(50)
  bio         String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_investor_profiles_user_id")
  @@map("investor_profiles")
}

model AdvisorProfile {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  displayName     String?   @map("display_name") @db.VarChar(255)
  phoneNumber     String?   @map("phone_number") @db.VarChar(20)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?   @db.VarChar(20)
  companyName     String?   @map("company_name") @db.VarChar(255)
  designation     String?   @db.VarChar(100)
  panNumber       String?   @map("pan_number") @db.VarChar(20)
  gstNumber       String?   @map("gst_number") @db.VarChar(20)
  addressLine1    String?   @map("address_line1") @db.VarChar(255)
  addressLine2    String?   @map("address_line2") @db.VarChar(255)
  city            String?   @db.VarChar(100)
  state           String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  websiteUrl      String?   @map("website_url")
  bio             String?
  profileImageUrl String?   @map("profile_image_url")
  workflowStatus  String?   @default("pending") @map("workflow_status") @db.VarChar(50)
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamp(6)
  isVerified      Boolean?  @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamp(6)
  followerCount   Int       @default(0) @map("follower_count")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user     User  @relation("AdvisorProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("AdvisorProfileApprover", fields: [approvedBy], references: [id], onDelete: NoAction)

  @@index([followerCount(sort: Desc)], map: "idx_advisor_profiles_follower_count")
  @@index([userId], map: "idx_advisor_profiles_user_id")
  @@index([workflowStatus], map: "idx_advisor_profiles_workflow_status")
  @@map("advisor_profiles")
}

model AdvisorCredential {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  credentialType  String    @map("credential_type") @db.VarChar(100)
  issuer          String?   @db.VarChar(255)
  licenseNumber   String?   @map("license_number") @db.VarChar(100)
  expiryDate      DateTime? @map("expiry_date") @db.Date
  fileUrl         String?   @map("file_url")
  status          String?   @default("pending") @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_advisor_credentials_status")
  @@index([userId], map: "idx_advisor_credentials_user_id")
  @@map("advisor_credentials")
}

model AdvisorExpertise {
  id             String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  specialization String    @db.VarChar(100)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, specialization])
  @@index([specialization], map: "idx_advisor_expertise_specialization")
  @@index([userId], map: "idx_advisor_expertise_user_id")
  @@map("advisor_expertise")
}

model AdvisorFollower {
  id         String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  investorId String    @map("investor_id") @db.Uuid
  advisorId  String    @map("advisor_id") @db.Uuid
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  advisor  User @relation("AdvisorFollowers", fields: [advisorId], references: [id], onDelete: Cascade)
  investor User @relation("FollowingAdvisors", fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, advisorId])
  @@index([advisorId], map: "idx_advisor_followers_advisor_id")
  @@index([investorId], map: "idx_advisor_followers_investor_id")
  @@map("advisor_followers")
}

// ============================================================================
// Content (articles, forum)
// ============================================================================

model Article {
  id               String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  authorId         String    @map("author_id") @db.Uuid
  title            String    @db.VarChar(500)
  content          String
  category         String?   @db.VarChar(100)
  tags             String[]
  featuredImageUrl String?   @map("featured_image_url")
  status           String?   @default("draft") @db.VarChar(50)
  rejectionReason  String?   @map("rejection_reason")
  publishedAt      DateTime? @map("published_at") @db.Timestamp(6)
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId], map: "idx_articles_author_id")
  @@index([category], map: "idx_articles_category")
  @@index([publishedAt], map: "idx_articles_published_at")
  @@index([status], map: "idx_articles_status")
  @@map("articles")
}

model ForumQuestion {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  authorId    String    @map("author_id") @db.Uuid
  title       String    @db.VarChar(500)
  content     String
  status      String?   @default("open") @db.VarChar(50)
  answerCount Int?      @default(0) @map("answer_count")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers ForumAnswer[]

  @@index([authorId], map: "idx_forum_questions_author_id")
  @@index([createdAt(sort: Desc)], map: "idx_forum_questions_created_at")
  @@index([status], map: "idx_forum_questions_status")
  @@map("forum_questions")
}

model ForumAnswer {
  id           String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  questionId   String    @map("question_id") @db.Uuid
  content      String
  votesCount   Int?      @default(0) @map("votes_count")
  isBestAnswer Boolean?  @default(false) @map("is_best_answer")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  author   User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  question ForumQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  votes    ForumAnswerVote[]

  @@index([authorId], map: "idx_forum_answers_author_id")
  @@index([isBestAnswer], map: "idx_forum_answers_is_best_answer")
  @@index([questionId], map: "idx_forum_answers_question_id")
  @@index([votesCount(sort: Desc)], map: "idx_forum_answers_votes_count")
  @@map("forum_answers")
}

model ForumAnswerVote {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  answerId  String    @map("answer_id") @db.Uuid
  voteType  String    @map("vote_type") @db.VarChar(50)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  answer ForumAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
  @@index([answerId], map: "idx_forum_answer_votes_answer_id")
  @@index([userId], map: "idx_forum_answer_votes_user_id")
  @@map("forum_answer_votes")
}

// ============================================================================
// Calculators / financial plans
// ============================================================================

model FinancialPlan {
  id             String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  calculatorType String    @map("calculator_type") @db.VarChar(50)
  name           String?   @db.VarChar(255)
  inputs         Json
  results        Json
  isDraft        Boolean?  @default(true) @map("is_draft")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([calculatorType], map: "idx_financial_plans_calculator_type")
  @@index([isDraft], map: "idx_financial_plans_is_draft")
  @@index([userId], map: "idx_financial_plans_user_id")
  @@map("financial_plans")
}

// ============================================================================
// Subscriptions / billing
// ============================================================================

model SubscriptionPlan {
  id            String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  slug          String    @unique @db.VarChar(50)
  name          String    @db.VarChar(100)
  priceInrPaise BigInt    @default(0) @map("price_inr_paise")
  billingPeriod String    @default("monthly") @map("billing_period") @db.VarChar(20)
  features      Json      @default("{}")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  subscriptions Subscription[]

  @@index([slug], map: "idx_subscription_plans_slug")
  @@map("subscription_plans")
}

model Subscription {
  id                     String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  planId                 String    @map("plan_id") @db.Uuid
  status                 String    @default("pending") @db.VarChar(50)
  razorpayOrderId        String?   @map("razorpay_order_id") @db.VarChar(100)
  razorpaySubscriptionId String?   @map("razorpay_subscription_id") @db.VarChar(100)
  razorpayPaymentId      String?   @map("razorpay_payment_id") @db.VarChar(100)
  currentPeriodStart     DateTime? @map("current_period_start") @db.Timestamp(6)
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamp(6)
  cancelledAt            DateTime? @map("cancelled_at") @db.Timestamp(6)
  createdAt              DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: NoAction)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([currentPeriodEnd], map: "idx_subscriptions_period_end")
  @@index([razorpayOrderId], map: "idx_subscriptions_razorpay_order")
  @@index([status], map: "idx_subscriptions_status")
  @@index([userId], map: "idx_subscriptions_user_id")
  @@map("subscriptions")
}

model Invoice {
  id                String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  subscriptionId    String    @map("subscription_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  amountInrPaise    BigInt    @map("amount_inr_paise")
  razorpayPaymentId String?   @map("razorpay_payment_id") @db.VarChar(100)
  razorpayInvoiceId String?   @map("razorpay_invoice_id") @db.VarChar(100)
  pdfUrl            String?   @map("pdf_url")
  issuedAt          DateTime? @default(now()) @map("issued_at") @db.Timestamp(6)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subscriptionId], map: "idx_invoices_subscription_id")
  @@index([userId], map: "idx_invoices_user_id")
  @@map("invoices")
}

// ============================================================================
// Internal — owned by the custom migration runner (scripts/migrate.ts).
// Prisma is aware of it so migrations don't try to drop it.
// ============================================================================

/// Tracking table for the raw-SQL migration runner. Not used by app code.
model MigrationRecord {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(255)
  executedAt DateTime? @default(now()) @map("executed_at") @db.Timestamp(6)

  @@map("migrations")
}
