{
  "name": "bloomkite",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "e2e": "playwright test",
    "db:migrate": "ts-node scripts/migrate.ts --env local",
    "db:test:migrate": "ts-node scripts/migrate.ts --env test",
    "db:prod:migrate": "ts-node scripts/migrate.ts --env prod",
    "db:seed": "ts-node database/seed.ts",
    "db:seed:mandatory": "ts-node database/seed.ts",
    "db:seed:optional": "ts-node database/seed.ts --expanded",
    "db:seed:expanded": "ts-node database/seed.ts --expanded",
    "prisma": "dotenv -e .env.local -- prisma",
    "prisma:test": "dotenv -e .env.test -- prisma",
    "prisma:prod": "dotenv -e .env.prod -- prisma",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:pull": "dotenv -e .env.local -- prisma db pull",
    "prisma:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e .env.prod -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.local -- prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "@supabase/supabase-js": "^2.105.3",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "postcss": "^8.5.14",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.8",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "pg": "^8.11.3",
    "react-email": "^6.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ws": "^8.15.0"
  }
}
